# Pass Authorization header to PHP (required for JWT auth on some Apache configs)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteEngine On
RewriteBase /services/OnlineMark/

# Static files: serve directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API routes → PHP (catch-all)
RewriteRule ^api/ api/index.php [QSA,L]

# Scan recognize → Python OMR on Render
RewriteRule ^api/scan/recognize/ https://onlinemark-backend.onrender.com/api/scan/recognize/ [R=307,L]

# SPA fallback
RewriteRule ^ index.html [L]
