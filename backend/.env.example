# Application
APP_NAME=云教学服务平台
APP_VERSION=1.0.0
DEBUG=False

# Security
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database: sqlite | mysql
DB_TYPE=sqlite
DB_SQLITE_PATH=./online_mark.db

# MySQL settings (used when DB_TYPE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=onlinemark
DB_PASSWORD=replace_me
DB_NAME=onlinemark

# Default admin for seed.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_REAL_NAME=系统管理员
